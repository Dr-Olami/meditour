---
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../design-system/components/organisms/Navbar';
import { Footer } from '../../design-system/components/organisms/Footer';
import { StepTimeline } from '../../design-system/components/organisms/StepTimeline';
import { getTranslations } from '../../lib/i18n';
import { getNavLinks } from '../../lib/navigation';
import { getFooterLegalLinks } from '../../lib/footer';

const t = getTranslations('bn');

const navLinks = getNavLinks('bn');
---

<Layout
  title={`${t.howItWorks.title} — ${t.site.name}`}
  description={t.howItWorks.subtitle}
  locale="bn"
>
  <Navbar
    brand={t.site.name}
    links={navLinks}
    cta={{ label: t.nav.cta, href: '/bn/#contact' }}
    client:load
  />

  <main class="container py-24 md:py-28">
    <div class="mb-12 max-w-2xl text-center md:text-left">
      <h1 class="font-display text-4xl font-bold text-ink md:text-5xl">{t.howItWorks.title}</h1>
      <p class="mt-4 text-lg text-ink/60">{t.howItWorks.subtitle}</p>
    </div>

    <StepTimeline steps={t.steps.items} />

    <div class="mt-16 text-center md:text-left">
      <a
        href="/bn/#contact"
        class="inline-flex items-center justify-center rounded-card bg-ink px-8 py-3 text-sm font-semibold text-white shadow-md hover:text-white"
      >
        {t.howItWorks.cta}
      </a>
    </div>
  </main>

  <Footer
    brand={t.site.name}
    legalLinks={getFooterLegalLinks('bn')}
    conciergeLabel={t.footer.concierge}
    conciergePrefix={t.footer.conciergePrefix}
    conciergeSuffix={t.footer.conciergeSuffix}
    copyright={`© ${new Date().getFullYear()} ${t.site.name}. ${t.footer.rights}`}
    address={t.footer.address}
  />
</Layout>
