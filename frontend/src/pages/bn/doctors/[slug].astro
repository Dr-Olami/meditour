---
import Layout from '../../../layouts/Layout.astro';
import { Navbar } from '../../../design-system/components/organisms/Navbar';
import { Footer } from '../../../design-system/components/organisms/Footer';
import { HospitalCard } from '../../../design-system/components/organisms/HospitalCard';
import { Icon } from '../../../design-system/components/atoms/Icon';
import { getTranslations } from '../../../lib/i18n';
import { getNavLinks } from '../../../lib/navigation';
import { getFooterLegalLinks } from '../../../lib/footer';
import { getDoctors, getHospitals, resolveHospital, entrySlug } from '../../../lib/content';
import { buildWhatsAppLink } from '../../../lib/whatsapp';

export async function getStaticPaths() {
  const [doctors, hospitals] = await Promise.all([getDoctors('bn'), getHospitals('bn')]);
  return doctors.map((entry) => {
    const hospital = resolveHospital(entry.data.hospitalId, hospitals);
    return {
      params: { slug: entrySlug(entry) },
      props: {
        doctor: entry.data,
        hospital: hospital ? { ...hospital.entry.data, slug: entrySlug(hospital.entry) } : null,
      },
    };
  });
}

const t = getTranslations('bn');
const { doctor, hospital } = Astro.props;

const navLinks = getNavLinks('bn');

const number = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '8801611892986';
const whatsappHref = buildWhatsAppLink(
  number,
  `Hi Khan Meditour, I would like to book an appointment with ${doctor.name}.`
);

const title = `${doctor.name} — ${doctor.specialty} | ${t.site.name}`;
const description = `${doctor.name} is a ${doctor.specialty} specialist with ${doctor.experienceYears} years of experience. Book a consultation through Khan Meditour.`;
---

<Layout title={title} description={description} locale="bn">
  <Navbar brand={t.site.name} links={navLinks} cta={{ label: t.nav.cta, href: '/bn/#contact' }} client:load />

  <main class="container py-24 md:py-28">
    <a href="/bn/doctors" class="mb-6 inline-flex items-center gap-2 text-sm font-medium text-ink/60 hover:text-ink">
      <Icon name="arrow-left" size={16} />
      বিশেষজ্ঞদের তালিকায় ফিরুন
    </a>

    <div class="grid gap-10 lg:grid-cols-[1fr_24rem]">
      <div>
        <div class="mb-6 flex items-start gap-6">
          {doctor.avatar ? (
            <img src={doctor.avatar} alt={doctor.name} class="h-24 w-24 rounded-full object-cover" />
          ) : (
            <div class="flex h-24 w-24 shrink-0 items-center justify-center rounded-full bg-ink text-3xl font-bold text-cream-100">
              {doctor.name.charAt(0)}
            </div>
          )}
          <div>
            <span class="inline-block rounded-full bg-cream-300 px-3 py-1 text-xs font-semibold text-ink/70">
              {doctor.specialty}
            </span>
            <h1 class="mt-3 font-display text-3xl font-bold text-ink md:text-4xl">{doctor.name}</h1>
            <p class="mt-1 text-ink/60">{doctor.qualification}</p>
            <p class="mt-1 text-sm text-ink/50">
              {t.doctors.detail.experienceLabel}: {doctor.experienceYears} {t.doctors.detail.years.replace('{{years}}', String(doctor.experienceYears))}
            </p>
          </div>
        </div>

        <div class="prose prose-ink max-w-none">
          <h2 class="mb-3 font-display text-xl font-semibold text-ink">সম্পর্কে</h2>
          <p class="text-ink/70 leading-relaxed">{doctor.bio}</p>
        </div>

        {doctor.languages && doctor.languages.length > 0 && (
          <div class="mt-8">
            <h3 class="mb-2 text-sm font-semibold uppercase tracking-wider text-ink/50">{t.doctors.detail.languagesLabel}</h3>
            <p class="text-ink/70">{doctor.languages.join(', ')}</p>
          </div>
        )}

        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/bn/#contact" class="inline-flex items-center justify-center rounded-card bg-gradient-to-r from-violet-600 to-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-md transition-opacity hover:opacity-90">
            {t.doctors.detail.bookCta}
          </a>
          <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 rounded-card border border-ink px-6 py-3 text-sm font-semibold text-ink transition-colors hover:bg-ink hover:text-white">
            <Icon name="whatsapp" size={18} />
            {t.doctors.detail.whatsappCta}
          </a>
        </div>
      </div>

      <aside>
        {hospital && (
          <div>
            <h2 class="mb-4 font-display text-lg font-semibold text-ink">{t.doctors.detail.atHospital}</h2>
            <HospitalCard
              hospital={{
                slug: hospital.slug,
                name: hospital.name,
                city: hospital.city,
                country: hospital.country,
                image: hospital.image,
                accreditations: hospital.accreditations,
              }}
              viewLabel={t.hospitals.viewHospital}
              locale="bn"
            />
          </div>
        )}
      </aside>
    </div>
  </main>

  <Footer
    brand={t.site.name}
    legalLinks={getFooterLegalLinks('bn')}
    conciergeLabel={t.footer.concierge}
    conciergePrefix={t.footer.conciergePrefix}
    conciergeSuffix={t.footer.conciergeSuffix}
    copyright={`© ${new Date().getFullYear()} ${t.site.name}. ${t.footer.rights}`}
    address={t.footer.address}
  />
</Layout>
