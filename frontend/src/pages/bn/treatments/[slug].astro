---
import Layout from '../../../layouts/Layout.astro';
import { Navbar } from '../../../design-system/components/organisms/Navbar';
import { Footer } from '../../../design-system/components/organisms/Footer';
import { DoctorCard } from '../../../design-system/components/organisms/DoctorCard';
import { Icon } from '../../../design-system/components/atoms/Icon';
import { getTranslations } from '../../../lib/i18n';
import { getNavLinks } from '../../../lib/navigation';
import { getFooterLegalLinks } from '../../../lib/footer';
import { getTreatments, getDoctors, getHospitals, resolveRelatedDoctors, resolveHospital, entrySlug } from '../../../lib/content';
import type { Doctor } from '../../../design-system/components/organisms/DoctorCard';

export async function getStaticPaths() {
  const [treatments, doctors, hospitals] = await Promise.all([
    getTreatments('bn'),
    getDoctors('bn'),
    getHospitals('bn'),
  ]);

  return treatments.map((entry) => {
    const related = resolveRelatedDoctors(entry.data.relatedDoctorSlugs, doctors).map((d) => {
      const hospital = resolveHospital(d.data.hospitalId, hospitals);
      return {
        name: d.data.name,
        specialty: d.data.specialty,
        qualification: d.data.qualification,
        experienceYears: d.data.experienceYears,
        avatar: d.data.avatar,
        href: `/bn/doctors/${entrySlug(d)}`,
        hospitalName: hospital?.name,
        hospitalHref: hospital?.href,
      };
    });
    return {
      params: { slug: entrySlug(entry) },
      props: { treatment: entry.data, related },
    };
  });
}

const t = getTranslations('bn');
const { treatment, related } = Astro.props;

const navLinks = getNavLinks('bn');

const title = `${treatment.name} — ${t.treatments.title} | ${t.site.name}`;
const description = treatment.description;
---

<Layout title={title} description={description} locale="bn">
  <Navbar brand={t.site.name} links={navLinks} cta={{ label: t.nav.cta, href: '/bn/#contact' }} client:load />

  <main class="container py-24 md:py-28">
    <a href="/bn/treatments" class="mb-6 inline-flex items-center gap-2 text-sm font-medium text-ink/60 hover:text-ink">
      <Icon name="arrow-left" size={16} />
      চিকিৎসার তালিকায় ফিরুন
    </a>

    <div class="grid gap-12 lg:grid-cols-[1fr_22rem]">
      <div>
        {treatment.category && (
          <span class="mb-3 inline-block rounded-full bg-cream-300 px-3 py-1 text-xs font-semibold text-ink/70">
            {treatment.category}
          </span>
        )}
        <h1 class="font-display text-4xl font-bold text-ink md:text-5xl">{treatment.name}</h1>
        {treatment.fromPrice && (
          <p class="mt-3 text-lg font-medium text-ink">
            {t.treatments.detail.fromPrice.replace('{{price}}', treatment.fromPrice)}
          </p>
        )}

        <div class="prose prose-ink mt-8 max-w-none">
          <h2 class="mb-3 font-display text-xl font-semibold text-ink">{t.treatments.detail.description}</h2>
          <p class="text-ink/70 leading-relaxed">{treatment.description}</p>
        </div>

        {treatment.procedures && treatment.procedures.length > 0 && (
          <div class="mt-10">
            <h2 class="mb-4 font-display text-xl font-semibold text-ink">{t.treatments.detail.procedures}</h2>
            <ul class="grid gap-3 sm:grid-cols-2">
              {treatment.procedures.map((procedure) => (
                <li class="flex items-start gap-3 rounded-card border border-cream-300 bg-cream-100 p-4 text-sm text-ink/80">
                  <span class="mt-0.5 h-2 w-2 shrink-0 rounded-full bg-violet-600" aria-hidden="true" />
                  {procedure}
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="mt-10">
          <a
            href="/bn/#contact"
            class="inline-flex items-center justify-center rounded-card bg-ink px-6 py-3 text-sm font-semibold text-white shadow-md hover:text-white"
          >
            {t.treatments.detail.inquiryCta}
          </a>
        </div>
      </div>

      <aside>
        {related.length > 0 && (
          <div>
            <h2 class="mb-4 font-display text-lg font-semibold text-ink">{t.treatments.detail.relatedDoctors}</h2>
            <div class="grid gap-4">
              {related.map((doctor: Doctor) => (
                <DoctorCard key={doctor.name} doctor={doctor} bookLabel={t.doctors.bookCta} />
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </main>

  <Footer
    brand={t.site.name}
    legalLinks={getFooterLegalLinks('bn')}
    conciergeLabel={t.footer.concierge}
    conciergePrefix={t.footer.conciergePrefix}
    conciergeSuffix={t.footer.conciergeSuffix}
    copyright={`© ${new Date().getFullYear()} ${t.site.name}. ${t.footer.rights}`}
    address={t.footer.address}
  />
</Layout>
