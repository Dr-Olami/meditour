---
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../design-system/components/organisms/Navbar';
import { Footer } from '../../design-system/components/organisms/Footer';
import { DoctorCard } from '../../design-system/components/organisms/DoctorCard';
import { Icon } from '../../design-system/components/atoms/Icon';
import { getTranslations } from '../../lib/i18n';
import { getNavLinks } from '../../lib/navigation';
import { getFooterLegalLinks } from '../../lib/footer';
import { getHospitals, getDoctors, resolveHospital, getDoctorsAtHospital, entrySlug } from '../../lib/content';
import { hospital as hospitalSchema, breadcrumbs } from '../../lib/schema';
import type { Doctor } from '../../design-system/components/organisms/DoctorCard';

export async function getStaticPaths() {
  const [hospitals, doctors] = await Promise.all([getHospitals('en'), getDoctors('en')]);
  return hospitals.map((entry) => {
    const slug = entrySlug(entry);
    const hospitalDoctors = getDoctorsAtHospital(slug, doctors).map((d) => {
      const hospital = resolveHospital(d.data.hospitalId, hospitals);
      return {
        name: d.data.name,
        specialty: d.data.specialty,
        qualification: d.data.qualification,
        experienceYears: d.data.experienceYears,
        avatar: d.data.avatar,
        href: `/doctors/${entrySlug(d)}`,
        hospitalName: hospital?.name,
        hospitalHref: hospital?.href,
      };
    });
    return {
      params: { slug },
      props: { hospital: entry.data, doctors: hospitalDoctors },
    };
  });
}

const t = getTranslations('en');
const { hospital, doctors } = Astro.props;

const navLinks = getNavLinks('en');

const title = `${hospital.name} — ${t.hospitals.title} | ${t.site.name}`;
const description = hospital.description;

const pageUrl = new URL(Astro.url.pathname, Astro.url.origin).toString();
const jsonLd = [
  hospitalSchema({
    name: hospital.name,
    url: pageUrl,
    description: hospital.description,
    image: hospital.image,
    city: hospital.city,
    country: hospital.country,
    accreditations: hospital.accreditations,
  }),
  breadcrumbs([
    { name: t.nav.home, url: new URL('/', Astro.url.origin).toString() },
    { name: t.hospitals.title, url: new URL('/hospitals', Astro.url.origin).toString() },
    { name: hospital.name, url: pageUrl },
  ]),
];
---

<Layout title={title} description={description} locale="en" image={hospital.image} jsonLd={jsonLd}>
  <Navbar brand={t.site.name} links={navLinks} cta={{ label: t.nav.cta, href: '/#contact' }} client:load />

  <main class="container py-24 md:py-28">
    <a href="/hospitals" class="mb-6 inline-flex items-center gap-2 text-sm font-medium text-ink/60 hover:text-ink">
      <Icon name="arrow-left" size={16} />
      Back to hospitals
    </a>

    <div class="grid gap-10 lg:grid-cols-[1fr_22rem]">
      <div>
        {hospital.image && (
          <div class="mb-8 overflow-hidden rounded-card border border-cream-300">
            <img src={hospital.image} alt={hospital.name} class="h-64 w-full object-cover md:h-80" />
          </div>
        )}

        <div class="mb-6 flex flex-wrap items-center gap-3">
          <h1 class="font-display text-3xl font-bold text-ink md:text-5xl">{hospital.name}</h1>
        </div>

        <p class="mb-8 flex items-center gap-2 text-ink/60">
          <Icon name="map-pin" size={18} />
          {hospital.city}, {hospital.country}
        </p>

        <div class="prose prose-ink max-w-none">
          <h2 class="mb-3 font-display text-xl font-semibold text-ink">About the hospital</h2>
          <p class="text-ink/70 leading-relaxed">{hospital.description}</p>
        </div>

        {hospital.amenities && hospital.amenities.length > 0 && (
          <div class="mt-10">
            <h2 class="mb-4 font-display text-xl font-semibold text-ink">{t.hospitals.amenities}</h2>
            <ul class="grid gap-3 sm:grid-cols-2">
              {hospital.amenities.map((amenity) => (
                <li class="flex items-center gap-3 rounded-card border border-cream-300 bg-cream-100 p-4 text-sm text-ink/80">
                  <span class="h-2 w-2 shrink-0 rounded-full bg-violet-600" aria-hidden="true" />
                  {amenity}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      <aside class="space-y-10">
        {hospital.accreditations && hospital.accreditations.length > 0 && (
          <div class="rounded-card border border-cream-300 bg-cream-100 p-6">
            <h2 class="mb-4 font-display text-lg font-semibold text-ink">{t.hospitals.accreditation}</h2>
            <div class="flex flex-wrap gap-2">
              {hospital.accreditations.map((badge) => (
                <span key={badge} class="rounded-full bg-cream-300 px-3 py-1 text-xs font-semibold text-ink/70">
                  {badge}
                </span>
              ))}
            </div>
          </div>
        )}

        {hospital.gallery && hospital.gallery.length > 0 && (
          <div>
            <h2 class="mb-4 font-display text-lg font-semibold text-ink">Gallery</h2>
            <div class="grid grid-cols-2 gap-3">
              {hospital.gallery.map((image) => (
                <img
                  src={image}
                  alt={`${hospital.name} gallery`}
                  class="aspect-video rounded-card object-cover"
                />
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>

    {doctors.length > 0 && (
      <section class="mt-16">
        <h2 class="mb-6 font-display text-2xl font-bold text-ink md:text-3xl">{t.hospitals.doctorsAtHospital}</h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {doctors.map((doctor: Doctor) => (
            <DoctorCard key={doctor.name} doctor={doctor} bookLabel={t.doctors.bookCta} />
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer
    brand={t.site.name}
    legalLinks={getFooterLegalLinks('en')}
    conciergeLabel={t.footer.concierge}
    conciergePrefix={t.footer.conciergePrefix}
    conciergeSuffix={t.footer.conciergeSuffix}
    copyright={`© ${new Date().getFullYear()} ${t.site.name}. ${t.footer.rights}`}
    address={t.footer.address}
  />
</Layout>
