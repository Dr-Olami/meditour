---
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../design-system/components/organisms/Navbar';
import { Footer } from '../../design-system/components/organisms/Footer';
import { DoctorCard } from '../../design-system/components/organisms/DoctorCard';
import { LeadForm } from '../../design-system/components/organisms/LeadForm';
import { CostEstimator } from '../../design-system/components/organisms/CostEstimator';
import { Icon } from '../../design-system/components/atoms/Icon';
import { getTranslations } from '../../lib/i18n';
import { getNavLinks } from '../../lib/navigation';
import { getFooterLegalLinks } from '../../lib/footer';
import { getTreatments, getDoctors, getHospitals, resolveRelatedDoctors, resolveHospital, entrySlug } from '../../lib/content';
import { medicalProcedure, breadcrumbs } from '../../lib/schema';
import { parsePrice } from '../../lib/pricing';
import { getTreatmentInquiryLink, getEstimateInquiryLink } from '../../lib/whatsapp';
import { ACCOMMODATIONS } from '../../content/accommodations';
import type { Doctor } from '../../design-system/components/organisms/DoctorCard';
import { LEAD_SOURCE } from '../../lib/crm';

export async function getStaticPaths() {
  const [treatments, doctors, hospitals] = await Promise.all([
    getTreatments('en'),
    getDoctors('en'),
    getHospitals('en'),
  ]);

  return treatments.map((entry) => {
    const related = resolveRelatedDoctors(entry.data.relatedDoctorSlugs, doctors).map((d) => {
      const hospital = resolveHospital(d.data.hospitalId, hospitals);
      return {
        name: d.data.name,
        specialty: d.data.specialty,
        qualification: d.data.qualification,
        experienceYears: d.data.experienceYears,
        avatar: d.data.avatar,
        href: `/doctors/${entrySlug(d)}`,
        hospitalName: hospital?.name,
        hospitalHref: hospital?.href,
      };
    });
    return {
      params: { slug: entrySlug(entry) },
      props: { treatment: entry.data, related },
    };
  });
}

const t = getTranslations('en');
const { treatment, related } = Astro.props;

const navLinks = getNavLinks('en');

const title = `${treatment.name} — ${t.treatments.title} | ${t.site.name}`;
const description = treatment.description;

const pageUrl = new URL(Astro.url.pathname, Astro.url.origin).toString();
const jsonLd = [
  medicalProcedure({
    name: treatment.name,
    url: pageUrl,
    description: treatment.description,
    image: treatment.image,
    procedureType: treatment.category,
  }),
  breadcrumbs([
    { name: t.nav.home, url: new URL('/', Astro.url.origin).toString() },
    { name: t.treatments.title, url: new URL('/treatments', Astro.url.origin).toString() },
    { name: treatment.name, url: pageUrl },
  ]),
];

const treatmentWhatsAppHref = getTreatmentInquiryLink(treatment.name);

const allTreatments = await getTreatments('en');
const treatmentOptions = allTreatments.map((entry) => ({
  value: entry.data.name,
  label: entry.data.name,
}));
const estimatorTreatmentOptions = allTreatments.map((entry) => ({
  value: entry.data.name,
  label: entry.data.name,
  cost: parsePrice(entry.data.fromPrice),
}));
const estimatorAccommodationOptions = ACCOMMODATIONS.map((a) => ({
  value: a.value,
  label: a.label,
  cost: a.cost,
}));
---

<Layout title={title} description={description} locale="en" image={treatment.image} jsonLd={jsonLd}>
  <Navbar brand={t.site.name} links={navLinks} cta={{ label: t.nav.cta, href: '/#contact' }} client:load />

  <main class="container py-24 md:py-28">
    <a href="/treatments" class="mb-6 inline-flex items-center gap-2 text-sm font-medium text-ink/60 hover:text-ink">
      <Icon name="arrow-left" size={16} />
      Back to treatments
    </a>

    <div class="grid gap-12 lg:grid-cols-[1fr_22rem]">
      <div>
        {treatment.category && (
          <span class="mb-3 inline-block rounded-full bg-cream-300 px-3 py-1 text-xs font-semibold text-ink/70">
            {treatment.category}
          </span>
        )}
        <h1 class="font-display text-4xl font-bold text-ink md:text-5xl">{treatment.name}</h1>
        {treatment.fromPrice && (
          <p class="mt-3 text-lg font-medium text-ink">
            {t.treatments.detail.fromPrice.replace('{{price}}', treatment.fromPrice)}
          </p>
        )}

        <div class="prose prose-ink mt-8 max-w-none">
          <h2 class="mb-3 font-display text-xl font-semibold text-ink">{t.treatments.detail.description}</h2>
          <p class="text-ink/70 leading-relaxed">{treatment.description}</p>
        </div>

        {treatment.procedures && treatment.procedures.length > 0 && (
          <div class="mt-10">
            <h2 class="mb-4 font-display text-xl font-semibold text-ink">{t.treatments.detail.procedures}</h2>
            <ul class="grid gap-3 sm:grid-cols-2">
              {treatment.procedures.map((procedure) => (
                <li class="flex items-start gap-3 rounded-card border border-cream-300 bg-cream-100 p-4 text-sm text-ink/80">
                  <span class="mt-0.5 h-2 w-2 shrink-0 rounded-full bg-violet-600" aria-hidden="true" />
                  {procedure}
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href={treatmentWhatsAppHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-card bg-ink px-6 py-3 text-sm font-semibold text-white shadow-md hover:text-white"
          >
            <Icon name="whatsapp" size={18} />
            {t.treatments.detail.inquiryCta}
          </a>
        </div>
      </div>

      <aside>
        {related.length > 0 && (
          <div>
            <h2 class="mb-4 font-display text-lg font-semibold text-ink">{t.treatments.detail.relatedDoctors}</h2>
            <div class="grid gap-4">
              {related.map((doctor: Doctor) => (
                <DoctorCard key={doctor.name} doctor={doctor} bookLabel={t.doctors.bookCta} />
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </main>

  <section class="bg-cream-100 py-20">
    <div class="container max-w-4xl">
      <h2 class="mb-6 text-center font-display text-3xl font-bold text-ink">Estimate your trip cost</h2>
      <CostEstimator
        client:load
        treatments={estimatorTreatmentOptions}
        accommodations={estimatorAccommodationOptions}
        getQuoteHref={(treatmentLabel, total) => getEstimateInquiryLink(treatmentLabel, total)}
      />
    </div>
  </section>

  <section id="contact" class="bg-cream-200 py-20">
    <div class="container grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="font-display text-3xl font-bold text-ink md:text-4xl">{t.cta.formTitle}</h2>
        <p class="mt-4 text-lg text-ink/60">{t.cta.subtitle}</p>
      </div>
      <div class="rounded-card border border-cream-300 bg-cream-100 p-6 shadow-base md:p-8">
        <h3 class="mb-6 font-display text-xl font-semibold text-ink">{t.cta.formTitle}</h3>
        <LeadForm
          client:load
          source={LEAD_SOURCE.TREATMENT_PAGE}
          defaultTreatment={treatment.name}
          treatments={treatmentOptions}
        />
      </div>
    </div>
  </section>

  <Footer
    brand={t.site.name}
    legalLinks={getFooterLegalLinks('en')}
    conciergeLabel={t.footer.concierge}
    conciergePrefix={t.footer.conciergePrefix}
    conciergeSuffix={t.footer.conciergeSuffix}
    copyright={`© ${new Date().getFullYear()} ${t.site.name}. ${t.footer.rights}`}
    address={t.footer.address}
  />
</Layout>
